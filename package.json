{
  "name": "fashion-tech-pack-v2",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "electron": "electron .",
    "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && NODE_ENV=development electron .\"",
    "server": "node server/index.js",
    "build": "next build",
    "build:win": "next build && electron-builder --win",
    "build:mac": "next build && electron-builder --mac",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-switch": "^1.2.6",
    "@react-pdf/renderer": "^4.3.2",
    "@sentry/browser": "^10.47.0",
    "@supabase/supabase-js": "^2.101.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "file-saver": "^2.0.5",
    "framer-motion": "^12.38.0",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.577.0",
    "next": "^16.1.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.71.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20.19.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/socket.io": "^3.0.1",
    "@vitejs/plugin-react": "^6.0.1",
    "browser-image-compression": "^2.0.2",
    "concurrently": "^9.2.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.7",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.vlv.techpackbuilder",
    "productName": "VLV Tech Pack Builder",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
